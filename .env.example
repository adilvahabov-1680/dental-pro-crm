# ─────────────────────────────────────────────────────────────
# Dental Pro CRM — пример .env
# Скопировать в .env (НЕ коммитить .env с реальными значениями).
# Development vs Production — см. комментарии у каждой переменной
# и docs/DEPLOYMENT.md (VPS) / docs/FREE_DEMO_DEPLOY.md (Vercel + Neon).
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string. Формат:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Development (Docker/портативная PostgreSQL, см. docs/SETUP.md):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dental_pro_crm?schema=public"
# Vercel + Neon: использовать прямой (non-pooled) connection string из Neon
#   (раздел "Connection string", не "Pooled connection string"):
#   DATABASE_URL="postgresql://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require"
# VPS/Production: отдельная БД/пользователь с собственным паролем.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dental_pro_crm?schema=public"

# Секрет подписи сессионного JWT (httpOnly cookie, lib/session.ts).
# Development: любое значение, в коде есть insecure-фолбэк.
# Production: ОБЯЗАТЕЛЬНО сгенерировать криптослучайный секрет:
#   openssl rand -base64 32
# Смена секрета мгновенно инвалидирует все активные сессии (max 12ч TTL).
SESSION_SECRET=change-me-in-production

# Mock-вход без БД (demo-пользователи из lib/constants.ts).
# Development (без БД): true
# Production / Vercel / Neon: ОБЯЗАТЕЛЬНО false — иначе вход возможен
# без проверки пароля из БД.
AUTH_MOCK=false

# Пароль demo-пользователей для prisma/seed.ts.
# Demo / Vercel: admin123 (используется при входе admin / admin123).
# Production-клиника: задать надёжный пароль или не запускать seed вовсе.
# НИКОГДА не использовать admin123 в реальной клинике.
SEED_DEMO_PASSWORD=admin123

# Показывать подсказку "Demo giriş: admin / admin123" на странице входа.
# Vercel-demo: true (задать в настройках Vercel → Environment Variables).
# Production-клиника / VPS: false или не задавать.
# NEXT_PUBLIC_* переменные встраиваются в бандл при сборке —
# изменение значения требует пересборки (на Vercel: redeploy).
NEXT_PUBLIC_DEMO_MODE=false

# Публичный базовый URL приложения — используется только для построения
# абсолютной ссылки /r/[token] в тексте напоминания (сессия 41,
# lib/patient-response.ts). Опционально для local dev/VPS: если не задан,
# ссылка строится из заголовков текущего запроса (host/x-forwarded-host).
# На Vercel/serverless (сессия 62) — задавать ВСЕГДА, не опционально: Vercel
# сам является «нестандартным proxy/CDN»-случаем, см. docs/FREE_DEMO_DEPLOY.md §5.
# NEXT_PUBLIC_APP_URL=https://app.dentalpro.az

# Персональный платформенный владелец (AV Systems).
# Если заданы EMAIL + PASSWORD, seed создаёт/обновляет super_admin-пользователя.
# PLATFORM_OWNER_LOGIN — короткий алиас для входа (без "@"), разрешается
#   в PLATFORM_OWNER_EMAIL без изменения кода и без пересборки.
# Никогда не коммитить .env с реальными значениями.
# PLATFORM_OWNER_LOGIN=
# PLATFORM_OWNER_EMAIL=
# PLATFORM_OWNER_PASSWORD=
# PLATFORM_OWNER_NAME=
