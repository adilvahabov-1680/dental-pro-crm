# ─────────────────────────────────────────────────────────────
# Dental Pro CRM — пример .env
# Скопировать в .env (НЕ коммитить .env с реальными значениями).
# Development vs Production — см. комментарии у каждой переменной
# и docs/DEPLOYMENT.md.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string. Формат:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Development (Docker/портативная PostgreSQL, см. docs/SETUP.md):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dental_pro_crm?schema=public"
# Production: отдельная БД/пользователь с собственным паролем, хост вашего
# PostgreSQL-сервера (тот же VPS или managed-инстанс). Не использовать
# креды postgres/postgres в production.

# Секрет подписи сессионного JWT (httpOnly cookie, lib/session.ts).
# Development: любое значение, в коде есть insecure-фолбэк.
# Production: ОБЯЗАТЕЛЬНО сгенерировать криптослучайный секрет, например:
#   openssl rand -base64 32
# Смена секрета мгновенно инвалидирует все активные сессии (max 12ч TTL).
SESSION_SECRET="change-me-in-production"

# ВРЕМЕННО: mock-вход без БД (demo-пользователи из lib/constants.ts,
# пароли не проверяются через БД). Используется только пока БД не поднята
# и миграции не применены.
# Development (без БД): "true"
# Production: ОБЯЗАТЕЛЬНО "false" — иначе вход возможен по demo-аккаунтам
# без пароля из БД.
AUTH_MOCK="true"

# Пароль demo-пользователей для prisma/seed.ts (admin@demo.dentalpro.az и т.д.).
# Development: можно оставить значение по умолчанию.
# Production: если seed запускается на проде (НЕ рекомендуется для боевой
# клиники) — задать собственный пароль; либо не запускать seed вовсе и
# создать сотрудников через /admin.
SEED_DEMO_PASSWORD="Demo1234!"
