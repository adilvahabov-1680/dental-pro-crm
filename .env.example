# PostgreSQL connection (обязательно для migrate/seed/реального auth).
# Креды dev-safe (локальная разработка): user=postgres, password=postgres.
# Запуск БД: docker compose up -d   ИЛИ   scripts\db-start.ps1 (см. docs/SETUP.md)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dental_pro_crm?schema=public"

# Секрет подписи сессионного JWT — в production сгенерировать криптослучайный
SESSION_SECRET="change-me-in-production"

# ВРЕМЕННО: mock-вход без БД (demo-пользователи из lib/constants.ts).
# Удалить/выключить, как только применены миграции и выполнен seed.
AUTH_MOCK="true"

# Пароль demo-пользователей для seed (не для production)
SEED_DEMO_PASSWORD="Demo1234!"
